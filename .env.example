DB_NAME=budget_buddy_db
DB_USER=budget_buddy_user
DB_PASSWORD=budget_buddy_password
DB_IMAGE_TAG=18.3-alpine

SPRING_PROFILES_ACTIVE=prod

BUDGET_BUDDY_API_IMAGE=docker.io/library/budget-buddy-api:0.0.1-SNAPSHOT
BUDGET_BUDDY_API_ACCESS_TOKEN_SECRET=REPLACE_WITH_MIN_32_RANDOM_BYTES_DO_NOT_USE_THIS_VALUE
BUDGET_BUDDY_API_ACCESS_TOKEN_VALIDITY_SECONDS=900
BUDGET_BUDDY_API_REFRESH_TOKEN_VALIDITY_SECONDS=1209600

DOCKER_PLATFORM=linux/arm64
